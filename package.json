{
  "name": "@rhyei/stylelint",
  "version": "0.0.1",
  "private": false,
  "license": "MIT",
  "author": "rhyei",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "prepublishOnly": "pnpm build",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "oxlint-tsgolint": "^0.23.0",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "stylelint": "^16.25.0",
    "stylelint-config-recess-order": "^7.6.0",
    "stylelint-config-recommended": "^18.0.0",
    "stylelint-config-standard": "^39.0.1",
    "stylelint-order": "^7.0.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm build && pnpm lint-staged",
    "prepare-commit-msg": "bun scripts/prepare-commit-msg.ts $1"
  },
  "lint-staged": {
    "*.{ts,tsx,json}": [
      "oxlint",
      "oxfmt"
    ]
  }
}
